# ============================================================
# TaskFlow — Environment Variables Reference
# Copy this file to .env and fill in values before running.
# Never commit the real .env to version control.
# ============================================================

# ---- Database ----------------------------------------------------------
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=                  # REQUIRED in all environments

# Python scripts only - Spring uses the Docker service name "db" internally
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- JWT ---------------------------------------------------------------
JWT_SECRET=                         # REQUIRED — min 32 chars (256-bit) for HS256

# ---- Mail (SMTP) -------------------------------------------------------
# REQUIRED in qa/prod. Optional in local (defaults to fake values).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@taskflow.com

# ---- App ---------------------------------------------------------------
# The public base URL used in email links (verify-email, reset-password, etc.)
# local:  http://localhost:4200  (default in application-local.yaml)
# qa:     http://qa.taskflow.com (default in application-qa.yaml)
# prod:   https://taskflow.com   (default in application-prod.yaml)
APP_BASE_URL=

# ---- Encryption --------------------------------------------------------
# REQUIRED — used to derive the AES-256-GCM key for field-level encryption.
# ENCRYPTION_PASSWORD: any strong secret string
# ENCRYPTION_SALT:     8-byte hex string — generate with: openssl rand -hex 8
ENCRYPTION_PASSWORD=
ENCRYPTION_SALT=
